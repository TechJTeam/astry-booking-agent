# --- Azure OpenAI (LLM) ---
AZURE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_API_KEY=
AZURE_GPT_5_2_DEPLOYMENT=gpt-5.2-chat-1
AZURE_API_VERSION=2025-01-01-preview

# --- astry-pos-be (REST backend, KHÔNG ghi thẳng DB) ---
POS_API_BASE_URL=http://localhost:3000
# X-Internal-Api-Key dùng riêng cho GET /public/staff (route này KHÔNG chấp nhận JWT forward,
# xem README mục "Deviation" — KHÔNG dùng chung key này cho các call JWT-forward khác).
POS_INTERNAL_API_KEY=

# --- Agent server ---
AGENT_API_KEY=dev-astry-booking-to-db-agent-key
AGENT_SERVER_PORT=8200

# --- Conversation persistence (Phase 7 — BR1-2 SRS: lưu toàn bộ hội thoại phục vụ Audit/Training) ---
# Để trống = rơi về MemoryConversationStore in-RAM của vanna (mất khi restart, chỉ chấp nhận dev local).
# Điền vào = dùng PostgresConversationStore (src/conversation_store.py). PHẢI là connection string
# của role RIÊNG của agent (booking_agent_svc), KHÔNG dùng lại DATABASE_URL của astry-pos-be —
# chạy db/setup_schema.sql một lần để tạo schema + role đó trước (xem README mục "Conversation store").
CONVERSATION_STORE_URL=
